<?xml version="1.0"?>
<robot name="flapping_platform" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="initial_positions_file" default="$(find flapping_platform_moveit_config)/config/real/initial_positions.yaml" />
  <xacro:property name="prefix" value=""/>
  <xacro:property name="link6_type" value="Link6_6fb"/>
  <xacro:property name="base_type" value="base_link_III"/>
  
  <xacro:include filename="$(find flapping_platform_description)/urdf/mech/rml_63.urdf.xacro" />
  <xacro:rml_63_arm
    prefix="${prefix}"
    link6_type_val="${link6_type}"
    base_type_val="${base_type}"/>
  <xacro:include filename="$(find flapping_platform_description)/urdf/mech/platform.urdf.xacro" />
  <!-- 各部件连接关系 -->
  <xacro:include filename="$(find flapping_platform_description)/urdf/mech/joint.urdf.xacro"/>
  <xacro:joint
    prefix="${prefix}"/>
  <!-- ros2_control配置 -->
  <xacro:include filename="$(find flapping_platform_description)/urdf/control/flapping_platform_mock.ros2_control.xacro" />
  <xacro:flapping_platform_real_ros2_control initial_positions_file="$(arg initial_positions_file)"/>
</robot>